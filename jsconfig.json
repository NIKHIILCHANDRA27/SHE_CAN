{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "checkJs": false
  },
  "exclude": [
    "node_modules",
    "backend/node_modules",
    "frontend/node_modules",
    "dist"
  ]
}
